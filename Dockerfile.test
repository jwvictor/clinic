FROM golang:1.25-bookworm

# Install common package managers and prereqs
RUN apt-get update && apt-get install -y \
    curl \
    git \
    sudo \
    unzip \
    ca-certificates \
    gnupg \
    libx11-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 (for npm-based CLI tools)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Homebrew (Linux)
RUN useradd -m -s /bin/bash tester \
    && echo "tester ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER tester
WORKDIR /home/tester

# Install Rust/Cargo as tester user (for cargo_install method)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y

RUN /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" \
    && echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"' >> ~/.bashrc

# Copy and build clinic
USER root
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o /usr/local/bin/clinic . \
    && chmod +x scripts/*.sh

# Switch to test user
USER tester
WORKDIR /home/tester
ENV GOPATH="/home/tester/go"
ENV GOTOOLCHAIN="auto"
ENV PATH="/home/tester/go/bin:/home/tester/.cargo/bin:/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:${PATH}"
# Force the embedded registry so tests use the compiled-in JSON, not the remote one
ENV CLINIC_REGISTRY_URL="file:///dev/null"

CMD ["/bin/bash"]
