{
  "name": "notion",
  "command": "notion",
  "description": "Notion CLI — manage pages, databases, blocks, comments, users",
  "language": "go",
  "category": "productivity",
  "version_command": "notion --version",
  "version_pattern": "notion version (\\S+)",
  "install_methods": [
    {
      "type": "brew",
      "platforms": [
        "macos",
        "linux"
      ],
      "formula": "4ier/tap/notion-cli"
    },
    {
      "type": "go_install",
      "platforms": [
        "macos",
        "linux"
      ],
      "package": "github.com/4ier/notion-cli@latest"
    }
  ],
  "auth": {
    "inject_type": "env",
    "env_var": "NOTION_API_KEY",
    "auth_check": "notion auth status",
    "auth_check_pattern": "(?i)✓|(?<![Nn]ot )authenticated",
    "auth_command": "notion auth login",
    "auth_hint": "Create an integration at https://www.notion.so/my-integrations to get your token"
  },
  "skill_template": "",
  "skills_source": "4ier/notion-cli"
}