{
  "name": "discordo",
  "command": "discordo",
  "description": "Discord terminal client — browse servers, channels, send messages",
  "language": "go",
  "category": "social",
  "version_command": "discordo --version",
  "version_pattern": "(\\S+)",
  "install_methods": [
    {
      "type": "go_install",
      "platforms": [
        "macos",
        "linux"
      ],
      "package": "github.com/ayn2op/discordo@latest"
    }
  ],
  "auth": {
    "inject_type": "env",
    "env_var": "DISCORD_TOKEN",
    "auth_check": "discordo --help",
    "auth_command": "discordo"
  },
  "skill_template": ""
}
