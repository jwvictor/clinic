{
  "name": "late",
  "command": "late",
  "description": "Zernio (formerly Late) — post to 13+ social platforms from one CLI",
  "language": "node",
  "category": "social",
  "version_command": "late --version",
  "version_pattern": "(\\S+)",
  "install_methods": [
    {
      "type": "npm",
      "platforms": [
        "macos",
        "linux"
      ],
      "package": "@getlatedev/cli",
      "global": true
    }
  ],
  "auth": {
    "inject_type": "env",
    "env_var": "LATE_API_KEY",
    "auth_check": "late auth:check",
    "auth_check_pattern": "valid|authenticated|ok",
    "auth_command": "late auth:set",
    "auth_hint": "Get your API key from your Zernio dashboard at https://zernio.com/dashboard/api"
  },
  "skill_template": "",
  "skills_source": "zernio-dev/zernio-cli",
  "skills_subdir": "."
}