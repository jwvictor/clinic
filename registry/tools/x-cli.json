{
  "name": "x-cli",
  "command": "x",
  "description": "X (Twitter) CLI — post, search, read timeline, manage account",
  "language": "rust",
  "category": "social",
  "version_command": "x --version",
  "version_pattern": "(\\S+)",
  "install_methods": [
    {
      "type": "brew",
      "platforms": [
        "macos",
        "linux"
      ],
      "formula": "x-cli"
    },
    {
      "type": "cargo_install",
      "platforms": [
        "macos",
        "linux"
      ],
      "package": "https://github.com/sferik/x-cli.git"
    }
  ],
  "auth": {
    "inject_type": "env",
    "env_var": "X_API_KEY",
    "auth_check": "x accounts",
    "auth_check_pattern": "\\S",
    "auth_command": "x authorize",
    "auth_hint": "Create an app at https://developer.x.com/portal, add your consumer key/secret to a profile, then run: x authorize"
  },
  "skill_template": ""
}
