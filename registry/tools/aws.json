{
  "name": "aws",
  "command": "aws",
  "description": "AWS CLI — EC2, S3, Lambda, IAM, CloudFormation, everything",
  "language": "python",
  "category": "cloud",
  "version_command": "aws --version",
  "version_pattern": "aws-cli/(\\S+)",
  "install_methods": [
    {
      "type": "brew",
      "platforms": [
        "macos",
        "linux"
      ],
      "formula": "awscli"
    }
  ],
  "auth": {
    "inject_type": "env",
    "env_var": "AWS_ACCESS_KEY_ID",
    "auth_check": "aws sts get-caller-identity",
    "auth_command": "aws configure"
  },
  "skill_template": ""
}