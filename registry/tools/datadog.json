{
  "name": "datadog",
  "command": "datadog-ci",
  "description": "Datadog CI CLI — upload test results, source maps, deploy markers",
  "language": "node",
  "category": "observability",
  "version_command": "datadog-ci version",
  "version_pattern": "(\\S+)",
  "install_methods": [
    {
      "type": "npm",
      "platforms": ["macos", "linux"],
      "package": "@datadog/datadog-ci",
      "global": true
    }
  ],
  "auth": {
    "inject_type": "env",
    "env_var": "DD_API_KEY",
    "auth_hint": "Get your keys from Datadog → Organization Settings → API Keys",
    "auth_env_prompts": [
      {"env_var": "DD_API_KEY", "label": "Datadog API Key", "required": true, "secret": true},
      {"env_var": "DD_APP_KEY", "label": "Datadog App Key", "required": false, "secret": true}
    ]
  }
}
