{
  "name": "postiz",
  "command": "postiz",
  "description": "Postiz — post and schedule to 20+ social platforms from one CLI",
  "language": "node",
  "category": "social",
  "version_command": "postiz --version",
  "version_pattern": "(\\S+)",
  "install_methods": [
    {
      "type": "npm",
      "platforms": ["macos", "linux"],
      "package": "postiz",
      "global": true
    }
  ],
  "auth": {
    "inject_type": "env",
    "env_var": "POSTIZ_API_KEY",
    "auth_hint": "Get your API key from https://app.postiz.com/settings/api or your self-hosted Postiz instance",
    "auth_env_prompts": [
      {"env_var": "POSTIZ_API_KEY", "label": "Postiz API Key", "required": true, "secret": true}
    ]
  },
  "skills_source": "gitroomhq/postiz-agent"
}
