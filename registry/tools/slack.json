{
  "name": "slack",
  "command": "slack",
  "description": "Slack CLI — create and manage Slack apps and workflows",
  "language": "go",
  "category": "productivity",
  "version_command": "slack --version",
  "version_pattern": "v(\\S+)",
  "install_methods": [
    {
      "type": "brew",
      "platforms": [
        "macos"
      ],
      "formula": "slack-cli"
    },
    {
      "type": "shell",
      "platforms": [
        "macos",
        "linux"
      ],
      "shell_command": "curl -fsSL https://downloads.slack-edge.com/slack-cli/install.sh | bash && sudo ln -sf $HOME/.slack/bin/slack /usr/local/bin/slack"
    }
  ],
  "auth": {
    "inject_type": "env",
    "env_var": "SLACK_TOKEN",
    "auth_check": "slack auth list",
    "auth_command": "slack login"
  },
  "skill_template": ""
}
